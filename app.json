{
  "expo": {
    "name": "FocoMais",
    "slug": "focomais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF5"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5C518"
      },
      "package": "com.wendeldavi.focusflow"
    },
    "platforms": ["android"],
    "plugins": [
      "expo-sqlite",
      "@react-native-community/datetimepicker",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "FocoWidget",
              "label": "FocoMais",
              "description": "Tarefas e foco do dia",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMinutes": 30
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "39f6c4b9-4b5b-42de-aa23-ff7c04057557"
      }
    }
  }
}
